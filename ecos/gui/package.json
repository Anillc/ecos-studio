{
  "name": "ecos-studio-gui",
  "version": "0.1.0-alpha.5",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "overrides": {
      "pixi.js": "^8.15.0"
    }
  },
  "scripts": {
    "dev": "pnpm run desktop:dev",
    "dev:reuse-api-server": "ECOS_REUSE_API_SERVER=1 pnpm run desktop:dev",
    "dev:vm": "LIBGL_ALWAYS_SOFTWARE=1 ELECTRON_DISABLE_SANDBOX=1 ECOS_ELECTRON_DISABLE_GPU=1 ECOS_ELECTRON_OPEN_DEVTOOLS=1 pnpm run desktop:dev",
    "dev:vm:reuse-api-server": "ECOS_REUSE_API_SERVER=1 LIBGL_ALWAYS_SOFTWARE=1 ELECTRON_DISABLE_SANDBOX=1 ECOS_ELECTRON_DISABLE_GPU=1 ECOS_ELECTRON_OPEN_DEVTOOLS=1 pnpm run desktop:dev",
    "build": "pnpm --filter @ecos-studio/renderer run typecheck && pnpm run desktop:build",
    "preview": "pnpm run desktop:preview",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "desktop:dev": "pnpm --filter @ecos-studio/desktop-electron run dev",
    "desktop:dev:reuse-api-server": "ECOS_REUSE_API_SERVER=1 pnpm --filter @ecos-studio/desktop-electron run dev",
    "desktop:build": "pnpm --filter @ecos-studio/desktop-electron run build",
    "desktop:preview": "pnpm --filter @ecos-studio/desktop-electron run preview",
    "desktop:package": "pnpm --filter @ecos-studio/desktop-electron run package",
    "desktop:test": "pnpm --filter @ecos-studio/desktop-electron run test",
    "desktop:typecheck": "pnpm --filter @ecos-studio/desktop-electron run typecheck",
    "renderer:dev": "pnpm --filter @ecos-studio/renderer run dev",
    "renderer:build": "pnpm --filter @ecos-studio/renderer run build",
    "renderer:preview": "pnpm --filter @ecos-studio/renderer run preview",
    "renderer:test": "pnpm --filter @ecos-studio/renderer run test",
    "renderer:typecheck": "pnpm --filter @ecos-studio/renderer run typecheck"
  }
}
